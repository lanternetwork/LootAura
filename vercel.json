{
  "buildCommand": "npm install --include=dev && npm run build",
  "installCommand": "npm install --include=dev",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/daily?mode=ingestion",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/geocode",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/reconciliation",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/discovery",
      "schedule": "0 4 * * *"
    }
  ]
}

