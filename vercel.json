{
  "buildCommand": "npm install --include=dev && npm run build",
  "installCommand": "npm install --include=dev",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/daily?mode=ingestion",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/geocode",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/reconciliation",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/discovery",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/discovery",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/ystm-coverage-audit",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/ystm-coverage-audit",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/ystm-missing-ingest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/ystm-missing-ingest",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/ystm-existing-refresh",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/ystm-existing-refresh",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/ystm-catalog-repair",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/ystm-catalog-repair",
      "schedule": "0 14 * * *"
    }
  ]
}

